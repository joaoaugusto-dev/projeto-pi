<%- include('./confirmLogoutModal.ejs') %>

<nav class="navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand" href="/" id="font-navbar">
      <img src="../../images/icon_navbar.png" alt="Logo" width="40" height="40" class="d-inline-block align-text-center me-2">
      <span class="text-white fw-bold">Sistema de Automação</span>
    </a>
    
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarContent">
      <ul class="navbar-nav ms-auto align-items-center">
        <li class="nav-item theme-control">
          <button id="lightThemeBtn" title="Tema Claro" class="theme-btn" onclick="setTheme('light')">☀️</button>
          <button id="darkThemeBtn" title="Tema Escuro" class="theme-btn" onclick="setTheme('dark')">🌙</button>
          <button id="contrastThemeBtn" title="Alto Contraste" class="theme-btn" onclick="setTheme('high-contrast')">◐</button>
        </li>
        
        <li class="nav-item font-control">
          <button id="decreaseFontBtn" class="font-btn" title="Diminuir fonte">A-</button>
          <button id="increaseFontBtn" class="font-btn" title="Aumentar fonte">A+</button>
        </li>

        <% if (!user) { %>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-light mx-2 px-4" href="/entrar">Entrar</a>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-light text-primary mx-2 px-4" href="/cadastro">Cadastrar</a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/preferencias">Preferências</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/historico">Histórico</a>
          </li>
          <li class="nav-item me-2">
            <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#confirmLogoutModal">Sair</a>
          </li>
          <li class="nav-item">
            <div class="zoom-profile">
              <a href="/dados">
                <% if (funcionario && funcionario.foto) { %>
                  <img class="rounded-circle border border-2 border-white" alt="foto-de-perfil" 
                       src="/uploads/<%= funcionario.foto %>" 
                       style="width: 40px; height: 40px; object-fit: cover;">
                <% } else { %>
                  <img class="rounded-circle border border-2 border-white" alt="foto-de-perfil" 
                       src="/images/perfil-default.png" 
                       style="width: 40px; height: 40px; object-fit: cover;">
                <% } %>
              </a>
            </div>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<style>
  .zoom-profile {
    transition: transform .2s;
  }
  
  .zoom-profile:hover {
    transform: scale(1.15);
  }

  .font-control {
    margin-right: 15px;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .font-control button {
    background: none;
    border: none;
    color: #fff;
    padding: 5px;
    cursor: pointer;
  }

  .font-control button:disabled {
    color: #666;
    cursor: not-allowed;
  }

  body {
    transition: all 0.3s ease;
  }

  [data-theme="dark"] {
    background-color: #1a1a1a;
    color: #ffffff;
  }

  [data-theme="dark"] .navbar {
    background-color: #000 !important;
  }

  [data-theme="dark"] .card {
    background-color: #2d2d2d;
    color: #ffffff;
  }

  [data-theme="high-contrast"] {
    background-color: #000000;
    color: #ffffff;
  }

  [data-theme="high-contrast"] .navbar {
    background-color: #000000 !important;
    border-bottom: 2px solid #ffffff;
  }

  [data-theme="high-contrast"] a {
    color: #ffff00 !important;
  }

  [data-theme="high-contrast"] .btn {
    background-color: #000000;
    color: #ffffff;
    border: 2px solid #ffffff;
  }

  .theme-control {
    margin-right: 15px;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .theme-control button {
    background: none;
    border: 1px solid #fff;
    color: #fff;
    padding: 5px 10px;
    cursor: pointer;
    border-radius: 4px;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .theme-control button.active {
    background-color: #fff;
    color: #000;
  }

  .theme-btn {
    width: 35px !important;
    height: 35px !important;
    border-radius: 50% !important;
    padding: 0 !important;
    font-size: 1.2rem;
    transition: all 0.3s ease;
  }

  .theme-btn:hover {
    transform: scale(1.1);
    background-color: rgba(255,255,255,0.2);
  }

  .theme-btn.active {
    background-color: #fff;
    color: var(--primary-color);
  }

  .font-btn {
    background: none;
    border: 1px solid rgba(255,255,255,0.5);
    color: #fff;
    border-radius: 4px;
    padding: 4px 8px;
    margin: 0 2px;
    transition: all 0.3s ease;
  }

  .font-btn:hover:not(:disabled) {
    background-color: rgba(255,255,255,0.2);
  }

  .font-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .navbar {
    padding: 0.8rem 0;
  }

  .nav-link {
    position: relative;
    font-weight: 500;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    background: var(--accent-color);
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }
</style>

<script>
  let currentFontSize = parseInt(localStorage.getItem('fontSize')) || 16;
  const minFontSize = 14;
  const maxFontSize = 20;

  function updateFontSize() {
    document.body.style.fontSize = currentFontSize + 'px';
    localStorage.setItem('fontSize', currentFontSize);
    
    document.getElementById('decreaseFontBtn').disabled = currentFontSize <= minFontSize;
    document.getElementById('increaseFontBtn').disabled = currentFontSize >= maxFontSize;
  }

  function increaseFont() {
    if (currentFontSize < maxFontSize) {
      currentFontSize += 2;
      updateFontSize();
    }
  }

  function decreaseFont() {
    if (currentFontSize > minFontSize) {
      currentFontSize -= 2;
      updateFontSize();
    }
  }

  // Aplicar tamanho da fonte salvo ao carregar a página
  document.addEventListener('DOMContentLoaded', () => {
    updateFontSize();
  });

  document.getElementById('confirmLogoutButton').addEventListener('click', async function() {
    try {
      const response = await fetch('/auth/logout', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      });

      if (response.ok) {
        window.location.href = '/';
      }
    } catch (error) {
      console.error('Erro:', error);
      document.getElementById('logoutErrorMessage').textContent = 'Erro ao fazer logout';
    }
  });

  // Gerenciamento de tema
  let currentTheme = localStorage.getItem('theme') || 'light';

  function setTheme(theme) {
    currentTheme = theme;
    document.body.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    
    // Atualizar botões ativos
    document.getElementById('lightThemeBtn').classList.toggle('active', theme === 'light');
    document.getElementById('darkThemeBtn').classList.toggle('active', theme === 'dark');
    document.getElementById('contrastThemeBtn').classList.toggle('active', theme === 'high-contrast');
  }

  // Aplicar tema salvo ao carregar a página
  document.addEventListener('DOMContentLoaded', () => {
    updateFontSize();
    setTheme(currentTheme);
  });

  document.addEventListener('DOMContentLoaded', function() {
    const theme = localStorage.getItem('theme') || 'light';
    setTheme(theme);
  });
</script>