<%- include('partials/header.ejs') %>
<%- include('partials/menu.ejs') %>

<body>
    <div class="container py-5">
        <% if (!user) { %>
            <div class="row align-items-center justify-content-between">
                <div class="col-md-6 mb-4 mb-md-0">
                    <h1 class="display-4 fw-bold mb-4" style="color: var(--primary-color)">Sistema de Automação Inteligente</h1>
                    <p class="lead mb-4">Controle automático de iluminação e temperatura personalizado para cada usuário.</p>
                    <div class="d-flex gap-3">
                        <a href="/entrar" class="btn btn-primary btn-lg px-4">Entrar</a>
                        <a href="/cadastro" class="btn btn-outline-primary btn-lg px-4">Cadastrar</a>
                    </div>
                </div>
                <div class="col-md-5">
                    <img src="/images/automation.svg" alt="Automação" class="img-fluid rounded-custom shadow-custom">
                </div>
            </div>
        <% } else { %>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-custom hover-lift">
                        <div class="card-body text-center p-4">
                            <div class="mb-4">
                                <% if (funcionario.foto) { %>
                                    <img src="/uploads/<%= funcionario.foto %>" alt="Foto de perfil" 
                                         class="rounded-circle border border-3 border-primary" 
                                         style="width: 120px; height: 120px; object-fit: cover;">
                                <% } else { %>
                                    <img src="/images/perfil-default.png" alt="Foto de perfil padrão" 
                                         class="rounded-circle border border-3 border-primary" 
                                         style="width: 120px; height: 120px; object-fit: cover;">
                                <% } %>
                            </div>
                            <h4 class="fw-bold mb-1"><%= funcionario.nome %> <%= funcionario.sobrenome %></h4>
                            <p class="text-muted mb-3">Matrícula: <%= funcionario.matricula %></p>
                            <a href="/dados" class="btn btn-outline-primary w-100">Ver Perfil</a>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-8">
                    <div class="row g-4">
                        <div class="col-12">
                            <div class="card border-0 shadow-custom hover-lift">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-4">Suas Preferências</h5>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="d-flex align-items-center mb-3">
                                                <i class="bi bi-thermometer-half fs-3 text-primary me-3"></i>
                                                <div>
                                                    <small class="text-muted d-block">Temperatura Preferida</small>
                                                    <h3 class="mb-0 fw-bold"><%= funcionario.temp_preferida %>°C</h3>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="d-flex align-items-center mb-3">
                                                <i class="bi bi-brightness-high fs-3 text-primary me-3"></i>
                                                <div>
                                                    <small class="text-muted d-block">Luminosidade Preferida</small>
                                                    <h3 class="mb-0 fw-bold"><%= funcionario.lumi_preferida %> lux</h3>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-0 shadow-custom hover-lift h-100">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-3">Configurações Atuais</h5>
                                    <div class="mb-4">
                                        <small class="text-muted d-block mb-1">Temperatura</small>
                                        <div class="d-flex align-items-baseline">
                                            <h2 class="mb-0 me-2"><span id="temp_atual">--</span>°C</h2>
                                            <small class="text-muted">Média: <span id="temp_media">--</span>°C</small>
                                        </div>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block mb-1">Luminosidade</small>
                                        <div class="d-flex align-items-baseline">
                                            <h2 class="mb-0 me-2"><span id="lumi_atual">--</span> lux</h2>
                                            <small class="text-muted">Média: <span id="lumi_media">--</span> lux</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-0 shadow-custom hover-lift h-100">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-4">Ações Rápidas</h5>
                                    <div class="d-grid gap-3">
                                        <a href="/preferencias" class="btn btn-primary">
                                            <i class="bi bi-sliders me-2"></i>Gerenciar Preferências
                                        </a>
                                        <a href="/historico" class="btn btn-outline-primary">
                                            <i class="bi bi-clock-history me-2"></i>Ver Histórico
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

    <%- include('partials/footer.ejs') %>
    <%- include('./partials/vlibras.ejs') %>
    
    <script>
        function atualizarDadosAmbiente() {
            fetch('/api/ambiente-atual')
                .then(response => response.json())
                .then(data => {
                    document.getElementById('temp_atual').textContent = data.temperatura || '--';
                    document.getElementById('lumi_atual').textContent = data.luminosidade || '--';
                    document.getElementById('temp_media').textContent = data.temperatura_media || '--';
                    document.getElementById('lumi_media').textContent = data.luminosidade_media || '--';
                })
                .catch(error => console.error('Erro ao atualizar dados:', error));
        }

        atualizarDadosAmbiente();
        setInterval(atualizarDadosAmbiente, 30000);
    </script>
</body>
