<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Histórico de Registros</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-5">
        <h2 class="text-center mb-4 font-scale">Histórico de Registros</h2>
        
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0 font-scale">Filtros</h5>
            </div>
            <div class="card-body">
                <form id="filterForm" class="row g-3">
                    <div class="col-md-4">
                        <label for="dataInicio" class="form-label font-scale">Data Início</label>
                        <input type="date" class="form-control font-scale" id="dataInicio" name="dataInicio">
                    </div>
                    <div class="col-md-4">
                        <label for="dataFim" class="form-label font-scale">Data Fim</label>
                        <input type="date" class="form-control font-scale" id="dataFim" name="dataFim">
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100 font-scale">Filtrar</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th class="font-scale">Data e Hora</th>
                        <th class="font-scale">Temperatura</th>
                        <th class="font-scale">Luminosidade</th>
                    </tr>
                </thead>
                <tbody id="historicoTableBody">
                    <% registros.forEach(function(registro) { %>
                        <tr>
                            <td class="font-scale"><%= new Date(registro.data_hora).toLocaleString() %></td>
                            <td class="font-scale"><%= registro.temperatura %>°C</td>
                            <td class="font-scale"><%= registro.luminosidade %> lux</td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        
        <div id="errorMessage" class="text-danger mt-3 text-center font-scale"></div>
    </div>
</body>
</html>