<%- include('partials/header.ejs') %>
<%- include('partials/menu.ejs') %>

<div class="container mt-5">
  <div class="card">
    <div class="card-header">
      <h2 class="text-center mb-0">Histórico de Ambientes</h2>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Data/Hora</th>
              <th>Temperatura</th>
              <th>Umidade</th>
              <th>Luminosidade</th>
            </tr>
          </thead>
          <tbody>
            <% historico.forEach(function(registro) { %>
              <tr>
                <td><%= new Date(registro.data_hora).toLocaleString('pt-BR') %></td>
                <td><%= registro.temperatura %>°C</td>
                <td><%= registro.humidade %>%</td>
                <td><%= registro.luminosidade %> lux</td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <% if (historico.length === 0) { %>
        <div class="text-center py-4">
          <p class="text-muted mb-0">Nenhum registro encontrado</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer.ejs') %>
<%- include('./partials/vlibras.ejs') %>