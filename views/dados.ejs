<%- include('partials/header.ejs') %>
<%- include('partials/menu.ejs') %>

<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h3 class="text-center">Meus Dados</h3>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-4">
                            <% if (account.foto) { %>
                                <img src="/uploads/<%= account.foto %>" alt="Foto de perfil" class="rounded-circle" style="width: 150px; height: 150px; object-fit: cover;">
                            <% } else { %>
                                <img src="/images/perfil-default.png" alt="Foto de perfil padrão" class="rounded-circle" style="width: 150px; height: 150px; object-fit: cover;">
                            <% } %>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <strong>Nome:</strong>
                                <p><%= account.nome %> <%= account.sobrenome %></p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <strong>Email:</strong>
                                <p><%= account.email %></p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <strong>CPF:</strong>
                                <p><%= account.cpf %></p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <strong>Data de Nascimento:</strong>
                                <p><%= account.nasc %></p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <strong>Telefone:</strong>
                                <p><%= account.telefone %></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

<%- include('partials/footer.ejs') %>
<%- include('./partials/vlibras.ejs') %>
</body>